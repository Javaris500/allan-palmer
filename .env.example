# Database (Prisma Postgres)
DATABASE_URL="prisma+postgres://localhost:51213/?api_key=YOUR_LOCAL_API_KEY"

# Anthropic (Claude Haiku for booking AI)
ANTHROPIC_API_KEY="sk-ant-api03-..."

# Resend (transactional emails)
RESEND_API_KEY="re_..."
EMAIL_FROM="no-reply@allanpalmerviolinist.com"

# Auth
NEXTAUTH_SECRET="generate-with: openssl rand -hex 32"
NEXTAUTH_URL="http://localhost:3000"

# Site URL (set in Vercel for production)
NEXT_PUBLIC_SITE_URL="https://allanpalmerviolinist.com"

# Admin seed credentials
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-this-password"
ADMIN_NAME="Allan Palmer"

# Upstash Redis — durable rate limiter for /api/leah/chat (and any future
# rate-limited routes). REQUIRED in production: without these, the limiter
# silently falls back to per-process in-memory counters. On Vercel that
# means each function instance gets its own bucket — effective limit is
# multiplied by the number of warm instances. Create a free Upstash Redis
# database at https://upstash.com and paste the REST credentials below.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
