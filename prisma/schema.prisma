generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════════════════════
// Enums
// ═══════════════════════════════════════════════════════

enum LessonType {
  PRIVATE
  GROUP
  MASTERCLASS
  ONLINE
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ALL_LEVELS
}

enum BookingStatus {
  PENDING
  REVIEWED
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum Role {
  USER
  ADMIN
}

enum PhotoCategory {
  WEDDING
  CONCERT
  CORPORATE
  PRIVATE
  PORTRAIT
  OTHER
}

// Where on the public site a photo is rendered. Drives the "Where is this
// used?" docs in the admin UI and lets singletons (hero, portrait) be
// modeled distinctly from the gallery list.
enum PhotoPlacement {
  GALLERY_CAROUSEL   // /gallery — many photos
  ABOUT_PORTRAIT     // /about hero — singleton
  HOMEPAGE_HERO      // / hero background — singleton (fallback when no video)
  FEATURED_TEASER    // / homepage gallery teaser — small set
  UNUSED             // uploaded but not placed anywhere yet
}

enum VideoPlacement {
  GALLERY_GRID       // /gallery video grid
  HOMEPAGE_HERO      // / hero video — singleton
  FEATURED_TEASER    // / homepage video teaser
  UNUSED
}

enum VideoCategory {
  WEDDING
  CONCERT
  CORPORATE
  PRIVATE
  LESSONS
  OTHER
}

// ═══════════════════════════════════════════════════════
// Auth (NextAuth v5 — Credentials + Resend magic link)
// ═══════════════════════════════════════════════════════

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  role           Role      @default(USER)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  leahConversations LeahConversation[]
  bookings          Booking[]
  uploadedPhotos    Photo[]
  uploadedVideos    Video[]
  adminActions      AdminAction[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ═══════════════════════════════════════════════════════
// Leah — AI assistant conversations
// ═══════════════════════════════════════════════════════

enum LeahMode {
  CUSTOMER
  ADMIN
}

enum LeahMessageRole {
  USER
  ASSISTANT
  TOOL
  SYSTEM
}

model LeahConversation {
  id        String   @id @default(cuid())
  userId    String
  mode      LeahMode
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages LeahMessage[]

  @@index([userId, updatedAt])
  @@map("leah_conversations")
}

model LeahMessage {
  id             String          @id @default(cuid())
  conversationId String
  role           LeahMessageRole
  content        String          @db.Text
  toolCalls      Json?
  createdAt      DateTime        @default(now())

  conversation LeahConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("leah_messages")
}

// ═══════════════════════════════════════════════════════
// Availability
// ═══════════════════════════════════════════════════════

model Availability {
  id          String      @id @default(cuid())
  // Exactly one of `dayOfWeek` or `date` is set:
  //  - dayOfWeek → recurring weekly rule (0=Sunday, 6=Saturday)
  //  - date      → one-off block for a specific calendar day
  dayOfWeek   Int?
  date        DateTime?   @db.Date
  startTime   String      @default("09:00")
  endTime     String      @default("17:00")
  lessonType  LessonType?
  isAvailable Boolean     @default(true)
  reason      String?

  @@index([dayOfWeek])
  @@index([date])
  @@map("availability")
}

// ═══════════════════════════════════════════════════════
// Event Bookings (authless — identified by contactEmail)
// ═══════════════════════════════════════════════════════

model Booking {
  id        String        @id @default(cuid())
  reference String        @unique // BK-20260215-A3F7
  status    BookingStatus @default(PENDING)

  // Optional link to a signed-in user who submitted this booking.
  // Null for anonymous submissions — /my-bookings then falls back to
  // contactEmail lookup. Signed-in submissions are stamped here so
  // the user can see their own history without an email challenge.
  userId    String?
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Event details (Phase 1)
  eventType      String
  eventDate      DateTime
  timePreference String   // Morning, Afternoon, Evening
  venue          String?
  guestCount     String?  // Under 50, 50-100, etc.
  setting        String?  // Indoor, Outdoor, Both

  // Performance details (Phase 2)
  duration            String   // 30 min, 1 hour, 2 hours, Custom
  musicStyles         String[]
  songRequests        String?  @db.Text
  specialRequirements String?  @db.Text

  // Contact details (Phase 3)
  contactName  String
  contactEmail String
  contactPhone String
  referralSource String?

  // Admin
  adminNotes String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  messages BookingMessage[]

  @@index([contactEmail])
  @@index([eventDate])
  @@index([status])
  @@index([userId])
  @@map("bookings")
}

model BookingMessage {
  id        String   @id @default(cuid())
  bookingId String
  fromAdmin Boolean  @default(false)
  content   String   @db.Text
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("booking_messages")
}

// ═══════════════════════════════════════════════════════
// Media — admin-managed photos (Vercel Blob) + videos (Mux)
// ═══════════════════════════════════════════════════════

model Photo {
  id           String         @id @default(cuid())
  title        String
  altText      String
  description  String?        @db.Text

  // Vercel Blob
  blobUrl      String         // public, CDN-served
  blobPathname String         // used to call del() from @vercel/blob
  contentType  String
  width        Int?
  height       Int?
  sizeBytes    Int

  // Display
  placement    PhotoPlacement @default(GALLERY_CAROUSEL)
  category     PhotoCategory  @default(OTHER)
  featured     Boolean        @default(false)
  displayOrder Int            @default(0)

  // Audit
  uploadedById String?
  uploadedBy   User?          @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?      // soft delete; cron hard-deletes from Blob

  @@index([placement, displayOrder])
  @@index([featured, displayOrder])
  @@index([category])
  @@index([deletedAt])
  @@map("photos")
}

model Video {
  id            String         @id @default(cuid())
  title         String
  description   String?        @db.Text

  // Mux
  muxAssetId    String?
  muxUploadId   String?        @unique // direct-upload session id (pre-asset)
  muxPlaybackId String?        @unique // null until Mux finishes processing
  muxStatus     String         @default("preparing") // preparing | ready | errored
  durationSec   Int?
  thumbnailTime Int            @default(8)

  // Display
  placement     VideoPlacement @default(GALLERY_GRID)
  category      VideoCategory  @default(WEDDING)
  featured      Boolean        @default(false)
  displayOrder  Int            @default(0)

  // Audit
  uploadedById  String?
  uploadedBy    User?          @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?

  @@index([placement, displayOrder])
  @@index([featured, displayOrder])
  @@index([category])
  @@index([deletedAt])
  @@index([muxStatus])
  @@map("videos")
}

model AdminAction {
  id        String   @id @default(cuid())
  userId    String?
  action    String   // e.g. 'photo.upload', 'photo.delete', 'video.upload'
  targetId  String?  // id of the resource acted on
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("admin_actions")
}
